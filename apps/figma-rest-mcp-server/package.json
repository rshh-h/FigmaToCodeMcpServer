{
  "name": "figma-to-code-mcp-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "figma-to-code-mcp-server": "./dist/index.js",
    "figma-to-code-mcp-server-http": "./dist/http.js",
    "figma-to-code-mcp-server-stdio": "./dist/stdio.js"
  },
  "scripts": {
    "build": "tsup src/index.ts src/http.ts src/stdio.ts --format esm --dts --clean",
    "dev": "tsx watch src/index.ts",
    "test": "vitest run",
    "type-check": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "verify:real": "tsx scripts/verify-real-figma.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "codegen-kernel": "workspace:*",
    "codegen-types": "workspace:*",
    "express": "^5.1.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "tsup": "^8.5.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
